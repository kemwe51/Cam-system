{
  "name": "@cam/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "dev": "NODE_OPTIONS=--conditions=source tsx watch src/server.ts",
    "test": "vitest run --config ../../vitest.workspace.ts src/server.test.ts"
  },
  "dependencies": {
    "@cam/ai": "file:../../packages/ai",
    "@cam/engine": "file:../../packages/engine",
    "@cam/importers": "file:../../packages/importers",
    "@cam/model": "file:../../packages/model",
    "@cam/shared": "file:../../packages/shared",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
